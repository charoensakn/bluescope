{
  "name": "bluescope",
  "description": "A lightweight, open-source intelligence toolkit built for investigative work.",
  "private": true,
  "version": "0.1.1",
  "main": "main/main.js",
  "author": "Charoensak Narkngam",
  "license": "MIT",
  "scripts": {
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:packages": "turbo build --filter=@repo/*",
    "build:apps": "turbo build --filter=main --filter=renderer",
    "build": "npm run build:packages && npm run build:apps",
    "dist:packages": "turbo run dist --filter=@repo/*",
    "dist:apps": "turbo run dist --filter=main --filter=renderer",
    "clean:packages": "turbo run clean --filter=@repo/*",
    "clean:apps": "turbo run clean --filter=main --filter=renderer",
    "clean": "npm run clean:packages && npm run clean:apps && rimraf ./release",
    "lint:packages": "turbo lint --filter=@repo/*",
    "lint:apps": "turbo lint --filter=main --filter=renderer",
    "lint": "npm run lint:packages && npm run lint:apps",
    "format:packages": "turbo format --filter=@repo/*",
    "format:apps": "turbo format --filter=main --filter=renderer",
    "format": "npm run format:packages && npm run format:apps",
    "check:packages": "turbo check --filter=@repo/*",
    "check:apps": "turbo check --filter=main --filter=renderer",
    "check": "npm run check:packages && npm run check:apps",
    "dev": "dotenv -- turbo dev --filter=main --filter=renderer",
    "make:version": "node make-version.js",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "dist": "npm run dist:packages && npm run dist:apps && npm run make:version && npm run package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "postinstall": "npm run rebuild"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.67",
    "@ai-sdk/azure": "^3.0.52",
    "@ai-sdk/cerebras": "^2.0.44",
    "@ai-sdk/cohere": "^3.0.29",
    "@ai-sdk/deepinfra": "^2.0.44",
    "@ai-sdk/deepseek": "^2.0.28",
    "@ai-sdk/fireworks": "^2.0.45",
    "@ai-sdk/google": "^3.0.59",
    "@ai-sdk/groq": "^3.0.34",
    "@ai-sdk/mistral": "^3.0.29",
    "@ai-sdk/openai": "^3.0.51",
    "@ai-sdk/openai-compatible": "^2.0.40",
    "@ai-sdk/perplexity": "^3.0.28",
    "@ai-sdk/togetherai": "^2.0.44",
    "@ai-sdk/xai": "^3.0.79",
    "@repo/agents": "*",
    "@repo/modules": "*",
    "@repo/repos": "*",
    "ai": "^6.0.150",
    "better-sqlite3": "^12.8.0",
    "electron-squirrel-startup": "^1.0.1",
    "incomplete-json-parser": "^1.1.5",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron/rebuild": "^4.0.3",
    "@inlang/paraglide-js": "^2.15.2",
    "@repo/agents": "^0.1.0",
    "@repo/repos": "^0.1.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^24.12.2",
    "copyfiles": "^2.4.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.1.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "turbo": "^2.9.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
