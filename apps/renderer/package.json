{
  "name": "renderer",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "message": "npx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "build": "npm run message && tsc -b && vite build",
    "clean": "rimraf ./dist && rimraf ../../renderer",
    "dist": "copyfiles -u 1 ./dist/**/* ../../renderer",
    "lint": "biome lint --fix",
    "format": "biome format --write",
    "check": "biome check --write",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/noto-sans-mono": "^5.2.10",
    "@fontsource-variable/noto-sans-thai": "^5.2.8",
    "@fontsource-variable/noto-sans-thai-looped": "^5.2.3",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@neo4j-nvl/base": "^1.1.0",
    "@neo4j-nvl/react": "^1.1.0",
    "@repo/modules": "*",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tiptap/markdown": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "dayjs": "^1.11.20",
    "globals": "^17.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.0",
    "swr": "^2.4.1",
    "vite": "^8.0.8",
    "zustand": "^5.0.12"
  }
}
